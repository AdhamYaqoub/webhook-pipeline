{
  "name": "webhook-pipeline",
  "version": "0.1.0",
  "private": true,
  "scripts": {
  "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
  "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
  "build": "tsc -p tsconfig.json",
  "start": "node dist/index.js",
  "lint": "ESLINT_USE_FLAT_CONFIG=false eslint -c .eslintrc.cjs src --ext .ts,.tsx",
  "test": "vitest run",
  "test:processing:echo": "vitest run test/processing.echo.test.ts",
  "test:processing:extract": "vitest run test/processing.extract.test.ts"
},
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "morgan": "^1.10.1",
    "node-fetch": "^3.3.2",
    "pg": "^8.20.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/express": "^4.17.25",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.4"
  }
}